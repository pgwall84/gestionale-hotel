# Copia questo file in .env e compila con i tuoi valori reali

# Connessione PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestionale_hotel
DB_USER=postgres
DB_PASSWORD=cambia_questa_password

# Chiave segreta per firmare i token JWT — usare una stringa lunga e casuale
JWT_SECRET=cambia_questa_chiave_segreta_molto_lunga

# Durata del token JWT (es. 8h = otto ore, 1d = un giorno)
JWT_EXPIRES_IN=8h

# Porta su cui gira il server Express
PORT=7001

# Ambiente (development / production)
NODE_ENV=development
